#include <iostream>
#include <string>
using namespace std;

int main() {

    string text = "ABABCABAB";
    string pattern = "ABAB";

    int n = text.length();
    int m = pattern.length();

    for (int i = 0; i <= n - m; i++) {
        int j;

        for (j = 0; j < m; j++) {
            if (text[i + j] != pattern[j])
                break;
        }

        if (j == m)
            cout << "Pattern found at position " << i << endl;
    }

    return 0;
}
